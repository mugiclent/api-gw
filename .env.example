# Docker image — managed by CI/CD pipeline (do not edit manually in production)
DOCKER_USERNAME=yourdockerhubusername
IMAGE_TAG=latest

NODE_ENV=development
PORT=3000

# JWT — RS256 public key (must match the private key used by user-service to sign tokens)
# Store PEM as single-line with literal \n separators
# Generate keypair: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Config repo — private GitHub repository hosting routes.yaml
# Format: https://raw.githubusercontent.com/{owner}/{repo}/{branch}/{path}
CONFIG_REPO_URL=https://raw.githubusercontent.com/your-org/katisha-config/main/api-gw/routes.yaml
# Fine-grained PAT with Contents: Read on the config repo (starts with github_pat_)
CONFIG_REPO_TOKEN=github_pat_your_token_here
# How often to poll for config changes (ms). Default: 30000 (30 s)
CONFIG_POLL_INTERVAL_MS=30000

# User service — internal Docker URL (for JWKS proxy)
USER_SERVICE_URL=http://katisha-user-service:3001
